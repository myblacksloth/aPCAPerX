# PCAPCaper runtime configuration without AI.
# Use this file as the .env template with docker-compose-noia.yml.

# 0 disables the application-level upload limit.
# If you use Nginx or another reverse proxy, configure its upload limit too.
PCAPCAPER_UPLOAD_MAX_MB=0

# Directory where the backend stores uploaded PCAP files during analysis.
# Files are removed in the /api/analyze endpoint cleanup block.
PCAPCAPER_TEMP_DIR=/tmp/pcapcaper

# Persist completed analysis reports on the backend.
# Use a Docker volume or a host-mounted path for this directory in production.
PCAPCAPER_ANALYSIS_STORAGE_ENABLED=1
PCAPCAPER_ANALYSIS_STORAGE_DIR=/data/pcapcaper/analyses
PCAPCAPER_ANALYSIS_STORAGE_MAX_ITEMS=50

# Upload chunk size in bytes. 1048576 = 1 MiB.
PCAPCAPER_UPLOAD_CHUNK_SIZE=1048576

# Maximum number of detailed packets included in the response JSON.
# 0 disables the limit, which is not recommended for large PCAP files.
PCAPCAPER_MAX_PACKET_LIST=1000

# Maximum packet_numbers stored for each flow.
# 0 disables the limit, which is not recommended for long flows.
PCAPCAPER_MAX_FLOW_PACKET_NUMBERS=200

# Maximum concurrency for opt-in external enrichment services.
PCAPCAPER_EXTERNAL_MAX_WORKERS=6

# Maximum number of public IPs enriched per request.
PCAPCAPER_MAX_ENRICHMENT_IPS=80

# Network timeouts for external services.
PCAPCAPER_HTTP_TIMEOUT_SECONDS=6
PCAPCAPER_SOCKET_TIMEOUT_SECONDS=5

# Optional: enable URLhaus in Security/DNS endpoints.
# URLHAUS_AUTH_KEY=

# Disable the technical AI assistant. The /api/ai-chat endpoint will return 503
# and no Ollama container or external model server is required.
PCAPCAPER_AI_ENABLED=0

# AI/Ollama settings are intentionally omitted for the no-AI profile.
