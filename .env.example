# PCAPCaper runtime configuration

# 0 = nessun limite applicativo sulla dimensione upload.
# Se usi Nginx o un reverse proxy, configura anche il limite proxy.
PCAPCAPER_UPLOAD_MAX_MB=0

# Directory dove il backend salva temporaneamente i PCAP durante l'analisi.
# I file vengono cancellati nel finally dell'endpoint /api/analyze.
PCAPCAPER_TEMP_DIR=/tmp/pcapcaper

# Dimensione chunk upload in byte. 1048576 = 1 MiB.
PCAPCAPER_UPLOAD_CHUNK_SIZE=1048576

# Numero massimo di pacchetti dettagliati inclusi nel JSON.
# 0 = nessun limite, sconsigliato su PCAP grandi.
PCAPCAPER_MAX_PACKET_LIST=1000

# Numero massimo di packet_numbers conservati per ogni flow.
# 0 = nessun limite, sconsigliato su flow lunghi.
PCAPCAPER_MAX_FLOW_PACKET_NUMBERS=200

# Concorrenza massima verso servizi esterni opt-in.
PCAPCAPER_EXTERNAL_MAX_WORKERS=6

# Numero massimo di IP pubblici arricchiti per richiesta.
PCAPCAPER_MAX_ENRICHMENT_IPS=80

# Timeout rete per servizi esterni.
PCAPCAPER_HTTP_TIMEOUT_SECONDS=6
PCAPCAPER_SOCKET_TIMEOUT_SECONDS=5

# Opzionale: abilita URLhaus negli endpoint Security/DNS.
# URLHAUS_AUTH_KEY=

# Lightweight technical AI assistant.
PCAPCAPER_AI_ENABLED=1
PCAPCAPER_AI_BASE_URL=http://ai:11434
PCAPCAPER_AI_MODEL=qwen2.5:0.5b
PCAPCAPER_AI_TIMEOUT_SECONDS=360
PCAPCAPER_AI_MAX_PACKETS=40
PCAPCAPER_AI_MAX_HISTORY_MESSAGES=8
PCAPCAPER_AI_NUM_PREDICT=384
PCAPCAPER_AI_NUM_CTX=2048

# Ollama runtime tuning for low-power hardware.
OLLAMA_NUM_PARALLEL=1
OLLAMA_MAX_LOADED_MODELS=1
