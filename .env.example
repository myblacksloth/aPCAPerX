# PCAPCaper runtime configuration

# 0 disables the application-level upload limit.
# If you use Nginx or another reverse proxy, configure its upload limit too.
PCAPCAPER_UPLOAD_MAX_MB=0

# Directory where the backend stores uploaded PCAP files during analysis.
# Files are removed in the /api/analyze endpoint cleanup block.
PCAPCAPER_TEMP_DIR=/tmp/pcapcaper

# Persist completed analysis reports on the backend.
# Use a Docker volume or a host-mounted path for this directory in production.
PCAPCAPER_ANALYSIS_STORAGE_ENABLED=1
PCAPCAPER_ANALYSIS_STORAGE_DIR=/data/pcapcaper/analyses
PCAPCAPER_ANALYSIS_STORAGE_MAX_ITEMS=50

# Upload chunk size in bytes. 1048576 = 1 MiB.
PCAPCAPER_UPLOAD_CHUNK_SIZE=1048576

# Maximum number of detailed packets included in the response JSON.
# 0 disables the limit, which is not recommended for large PCAP files.
PCAPCAPER_MAX_PACKET_LIST=1000

# Maximum packet_numbers stored for each flow.
# 0 disables the limit, which is not recommended for long flows.
PCAPCAPER_MAX_FLOW_PACKET_NUMBERS=200

# Maximum concurrency for opt-in external enrichment services.
PCAPCAPER_EXTERNAL_MAX_WORKERS=6

# Maximum number of public IPs enriched per request.
PCAPCAPER_MAX_ENRICHMENT_IPS=80

# Network timeouts for external services.
PCAPCAPER_HTTP_TIMEOUT_SECONDS=6
PCAPCAPER_SOCKET_TIMEOUT_SECONDS=5

# Optional: enable URLhaus in Security/DNS endpoints.
# URLHAUS_AUTH_KEY=

# Authentication and PostgreSQL user database.
PCAPCAPER_AUTH_ENABLED=1
PCAPCAPER_POSTGRES_DB=pcapcaper
PCAPCAPER_POSTGRES_USER=pcapcaper
PCAPCAPER_POSTGRES_PASSWORD=pcapcaper
PCAPCAPER_DATABASE_URL=postgresql://pcapcaper:pcapcaper@db:5432/pcapcaper
PCAPCAPER_SESSION_COOKIE_NAME=pcapcaper_session
PCAPCAPER_SESSION_SECRET=change-me-in-production
PCAPCAPER_SESSION_TTL_HOURS=168
PCAPCAPER_WEBAUTHN_RP_ID=localhost
PCAPCAPER_WEBAUTHN_RP_NAME=PCAPCaper
PCAPCAPER_WEBAUTHN_ORIGIN=http://localhost:3000

# Lightweight technical AI assistant.
PCAPCAPER_AI_ENABLED=1

# Ollama endpoint selection:
# - container: use the Ollama service from docker-compose at http://ai:11434.
# - host: use an Ollama server already running on the local macOS machine.
# PCAPCAPER_AI_BASE_URL, when set, overrides the mode/host/port values below.
PCAPCAPER_AI_OLLAMA_MODE=container
# PCAPCAPER_AI_BASE_URL=

# Host-mode connection settings.
# Use host.docker.internal when the backend runs in Docker on macOS.
# Use the Mac LAN IP, such as 192.168.1.20, when another machine/container must reach it.
PCAPCAPER_AI_OLLAMA_HOST=host.docker.internal
PCAPCAPER_AI_OLLAMA_PORT=11434

# Model and generation limits. The default model is intentionally small for
# Raspberry Pi 5 / 4 GB RAM; use local-ai.md for stronger macOS model choices.
PCAPCAPER_AI_MODEL=qwen2.5:0.5b
PCAPCAPER_AI_TIMEOUT_SECONDS=360
PCAPCAPER_AI_MAX_PACKETS=40
PCAPCAPER_AI_MAX_HISTORY_MESSAGES=8
PCAPCAPER_AI_NUM_PREDICT=384
PCAPCAPER_AI_NUM_CTX=2048
# Approximate maximum prompt size in characters before the backend prunes the
# technical evidence. Keep this below the model context window to avoid Ollama
# truncating the prompt internally.
PCAPCAPER_AI_PROMPT_MAX_CHARS=3072

# Ollama runtime tuning for low-power hardware. These variables are consumed by
# the docker-compose Ollama service and can also be exported before starting
# Ollama locally.
OLLAMA_NUM_PARALLEL=1
OLLAMA_MAX_LOADED_MODELS=1
