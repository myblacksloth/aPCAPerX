# PCAPCaper runtime configuration for an external Ollama server.
# Use this file as the .env template when backend/frontend run in Docker on one
# host, while Ollama runs on another host at 192.168.1.123:11434.

# External enrichment settings copied from the current .env.
PCAPCAPER_UPLOAD_MAX_MB=0
PCAPCAPER_TEMP_DIR=/tmp/pcapcaper
PCAPCAPER_UPLOAD_CHUNK_SIZE=1048576
PCAPCAPER_MAX_PACKET_LIST=1000
PCAPCAPER_MAX_FLOW_PACKET_NUMBERS=200
PCAPCAPER_ANALYSIS_STORAGE_ENABLED=1
PCAPCAPER_ANALYSIS_STORAGE_DIR=/data/pcapcaper/analyses
PCAPCAPER_ANALYSIS_STORAGE_MAX_ITEMS=50
PCAPCAPER_EXTERNAL_MAX_WORKERS=6
PCAPCAPER_MAX_ENRICHMENT_IPS=80
PCAPCAPER_HTTP_TIMEOUT_SECONDS=6
PCAPCAPER_SOCKET_TIMEOUT_SECONDS=5
# URLHAUS_AUTH_KEY=

# Enable the technical AI assistant.
PCAPCAPER_AUTH_ENABLED=1
PCAPCAPER_POSTGRES_DB=pcapcaper
PCAPCAPER_POSTGRES_USER=pcapcaper
PCAPCAPER_POSTGRES_PASSWORD=pcapcaper
PCAPCAPER_DATABASE_URL=postgresql://pcapcaper:pcapcaper@db:5432/pcapcaper
PCAPCAPER_SESSION_COOKIE_NAME=pcapcaper_session
PCAPCAPER_SESSION_SECRET=change-me-in-production
PCAPCAPER_SESSION_TTL_HOURS=168
PCAPCAPER_WEBAUTHN_RP_ID=localhost
PCAPCAPER_WEBAUTHN_RP_NAME=PCAPCaper
PCAPCAPER_WEBAUTHN_ORIGIN=http://localhost:7000

# Enable the technical AI assistant.
PCAPCAPER_AI_ENABLED=1

# Use an Ollama server outside this Docker Compose stack.
PCAPCAPER_AI_OLLAMA_MODE=host
PCAPCAPER_AI_OLLAMA_HOST=192.168.1.123
PCAPCAPER_AI_OLLAMA_PORT=11434

# Explicit URL override for the remote Ollama API. Keeping this set makes the
# configuration unambiguous even when the Docker host is not the Ollama host.
PCAPCAPER_AI_BASE_URL=http://192.168.1.123:11434

# The model name must already exist on the remote Ollama server.
# Install it on 192.168.1.123 with: ollama pull deepseek-r1:32b
PCAPCAPER_AI_MODEL=deepseek-r1:32b

# Generation limits tuned for a stronger reasoning model.
PCAPCAPER_AI_TIMEOUT_SECONDS=360
PCAPCAPER_AI_MAX_PACKETS=40
PCAPCAPER_AI_MAX_HISTORY_MESSAGES=8
PCAPCAPER_AI_NUM_PREDICT=768
PCAPCAPER_AI_NUM_CTX=8192
# Approximate maximum prompt size in characters before the backend prunes the
# technical evidence. This avoids Ollama's "truncating input prompt" path.
PCAPCAPER_AI_PROMPT_MAX_CHARS=12000

# These only affect Ollama if exported on the Ollama host before starting it.
# They do not tune the remote server when this file is loaded only by the app.
OLLAMA_NUM_PARALLEL=1
OLLAMA_MAX_LOADED_MODELS=1
